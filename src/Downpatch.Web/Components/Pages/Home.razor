@page "/"

@using Microsoft.AspNetCore.Components.Web

<PageTitle>Downpatch — The Open Speedrunning Knowledge Base</PageTitle>

<HeadContent>
    <meta name="description"
          content="Master the run with Downpatch. Access precise setups, optimized routing, engine mechanics, and downpatching guides to eliminate execution guesswork." />

    <link rel="canonical" href="https://downpatch.com/" />

    <meta property="og:title" content="Downpatch Wiki - Master Your Speedrun Setups" />
    <meta property="og:description"
          content="The ultimate execution database. Get precise setups, downpatching guides, and technical routing to optimize your run." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://downpatch.com/" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Downpatch Wiki - Master Your Speedrun Setups" />
    <meta name="twitter:description"
          content="Stop guessing on your setups. Access precise downpatching instructions, visual trick cues, and route logic." />
</HeadContent>

<header class="home-hero" aria-labelledby="home-title">
    <div class="home-hero-inner">
        <p class="home-kicker">Knowledge Base</p>
        <h1 id="home-title" class="home-title">
            The open knowledge base for faster runs.
        </h1>

        <p class="home-lead">
            Eliminate execution guesswork. Access community-driven breakdowns for difficult tricks, route optimization, engine exploitation, and legacy research.
        </p>

        <nav class="home-actions" aria-label="Primary actions">
            <a class="home-action primary" href="/guide">Browse Games</a>
            <a class="home-action" href="https://github.com/downpatch/content">Contribute</a>
        </nav>
    </div>
</header>

<section class="home-body" aria-label="Wiki overview">
    <div class="home-cards">

        <section class="home-card" aria-labelledby="learn">
            <h2 id="learn" class="home-h2">Learn the Meta</h2>

            <p class="muted">
                Whether you are learning your very first level or trying to optimize a legacy route, 
                get the exact tools, video cues, and execution breakdowns you need to level up your runs.
            </p>

            <ul class="home-list">
                <li>Get consistent at tough skips</li>
                <li>Understand the logic behind the routes</li>
                <li>Visualize setups with video tutorials</li>
                <li>Track your progress against benchmark times</li>
            </ul>
        </section>

        <section class="home-card" aria-labelledby="research">
            <h2 id="research" class="home-h2">Find the Next Skip</h2>

            <p class="muted">
                Equip yourself with the technical documentation needed to break open new levels, 
                troubleshoot inconsistent glitches, and dive deep into the game's core logic.
            </p>

            <ul class="home-list">
                <li>Understand the precise parameters of a glitch</li>
                <li>Visualize trigger volumes</li>
                <li>Learn how the game handles asset loads</li>
                <li>Develop new routing theories and strategies</li>
            </ul>
        </section>

        <section class="home-card" aria-labelledby="history">
            <h2 id="history" class="home-h2">Explore the Legacy</h2>

            <p class="muted">
                See how the meta evolved. Trace the lineage of today's fastest strategies through a permanent 
                archive of route discoveries, retired world records, and the community breakthroughs that made them possible.
            </p>

            <ul class="home-list">
                <li>Study the origin of classic skips</li>
                <li>Track the timeline of world record breakthroughs</li>
                <li>Review legacy routes used in historic runs</li>
                <li>Access community research and patch history</li>
            </ul>

            <p>
                <a href="https://github.com/downpatch/content" class="home-link">
                    Help document history on GitHub
                </a>
            </p>
        </section>

    </div>
</section>
